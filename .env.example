# Copy to .env.local and fill in to enable optional integrations.
# Leaving these blank is fine — the site works fully without them.

# Google Analytics 4 measurement ID (loads only after cookie consent)
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher ID, e.g. ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google reCAPTCHA v3 (invisible, runs on all pages and scores traffic).
# Public site key — optional; defaults to the project key when blank.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LcofjstAAAAAHtOPh5mFiSqHAOVxbaxDHM_1JOr
# Server-side secret key. Required to actually verify tokens; keep it private.
SECRET_RECAPTCHA=

# Search-engine site ownership verification (paste the token from each console).
# Google Search Console → Settings → Ownership → HTML tag (content="...").
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → meta tag (content="...").
BING_SITE_VERIFICATION=
